{
  "title": "LSTM Monitoring",
  "uid": "lstm-monitoring",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "MAE — Erreur Absolue Moyenne",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 40 }
            ]
          },
          "unit": "€"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "lstm_model_mae", "legendFormat": "MAE", "refId": "A" }]
    },
    {
      "id": 2,
      "title": "RMSE — Erreur Quadratique",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "€"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "lstm_model_rmse", "legendFormat": "RMSE", "refId": "A" }]
    },
    {
      "id": 3,
      "title": "MAPE — Erreur en Pourcentage",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "percent"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [{ "expr": "lstm_model_mape", "legendFormat": "MAPE", "refId": "A" }]
    },
    {
      "id": 4,
      "title": "Prédictions totales",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "lstm_predictions_total", "legendFormat": "Prédictions", "refId": "A" }]
    },
    {
      "id": 5,
      "title": "Entraînements totaux",
      "type": "stat",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "lstm_training_total", "legendFormat": "Entraînements", "refId": "A" }]
    },
    {
      "id": 6,
      "title": "Erreurs",
      "type": "stat",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "expr": "lstm_errors_total", "legendFormat": "Erreurs", "refId": "A" }]
    },
    {
      "id": 7,
      "title": "CPU — Prometheus",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit"
        }
      },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "CPU", "refId": "A" }]
    },
    {
      "id": 8,
      "title": "RAM — Prometheus",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes"
        }
      },
      "targets": [{ "expr": "process_resident_memory_bytes", "legendFormat": "RAM", "refId": "A" }]
    },
    {
      "id": 9,
      "title": "Durée des prédictions (p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(lstm_prediction_duration_seconds_bucket[5m]))", "legendFormat": "p99 prédiction", "refId": "A" }]
    },
    {
      "id": 10,
      "title": "Durée des entraînements (p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s"
        }
      },
      "targets": [{ "expr": "histogram_quantile(0.99, rate(lstm_training_duration_seconds_bucket[5m]))", "legendFormat": "p99 entraînement", "refId": "A" }]
    }
  ]
}
